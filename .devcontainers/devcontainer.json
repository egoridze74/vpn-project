{
  "name": "fedora40-dev",
  "build": {
    "dockerfile": "fedora40.Dockerfile"
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--device=/dev/net/tun",
    "--privileged"
  ],
  "postCreateCommand": "python3 -m pip install --user pyyaml",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  },
  "forwardPorts": [5000, 1194],
  "portsAttributes": {
    "5000": {
      "label": "Web Server",
      "onAutoForward": "notify"
    },
    "1194": {
      "label": "VPN Server",
      "onAutoForward": "ignore"
    }
  }
}